<script>
/* Robustly start muted background videos (handles blob-src swap in the
   standalone build and browser autoplay policies). */
(function () {
  /* pick the hero source per device — mobile-framed clip on phones,
     landscape loop on desktop; only the chosen file downloads */
  (function () {
    var v = document.querySelector(".hero-video[data-src]");
    if (!v) return;
    var isMobile = window.matchMedia("(max-width: 640px)").matches;
    var src = (isMobile && v.getAttribute("data-src-mobile")) || v.getAttribute("data-src");
    if (v.getAttribute("src") !== src) { v.setAttribute("src", src); v.load(); }
  })();
  function kick() {
    document.querySelectorAll("video[autoplay]").forEach(function (v) {
      v.muted = true; v.defaultMuted = true;
      var p = v.play();
      if (p && p.catch) p.catch(function () {});
    });
  }
  document.querySelectorAll("video[autoplay]").forEach(function (v) {
    ["loadeddata", "canplay"].forEach(function (ev) { v.addEventListener(ev, kick); });
  });
  window.addEventListener("load", kick);
  document.addEventListener("visibilitychange", function () { if (!document.hidden) kick(); });
  window.addEventListener("pointerdown", kick, { once: true });
  kick();
})();

/* Brand wordmark rolls between English and Kannada (masked signage roll) */
(function () {
  var roll = document.getElementById("wordmark");
  if (!roll) return;
  setInterval(function () { roll.classList.toggle("kn"); }, 3800);
})();
</script>

