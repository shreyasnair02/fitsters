# ---- Build stage ----
FROM node:22-alpine AS builder
WORKDIR /build

# Install deps against the lockfile first (better layer caching)
COPY package.json package-lock.json ./
RUN npm ci

# Copy source and build the static site
COPY . .
RUN npm run build

# ---- Caddy stage ----
FROM caddy:2-alpine

COPY --from=builder /build/dist/ /srv/web/
COPY infrastructure/caddy/Caddyfile /etc/caddy/Caddyfile

EXPOSE 80

CMD ["caddy", "run", "--config", "/etc/caddy/Caddyfile"]
